{
  "name": "stelltask",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "db:generate": "cd apps/api && prisma generate",
    "db:migrate": "cd apps/api && prisma migrate dev",
    "db:studio": "cd apps/api && prisma studio",
    "db:seed": "cd apps/api && prisma db seed",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
